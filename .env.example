# --- PROMPT TO SQL ORCHESTRATOR CONFIG ---

# LLM Providers
GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# Model Routing (4-Tier Orchestration)
GEMINI_LITE=gemini/gemini-2.0-flash-lite
GEMINI_FLASH=gemini/gemini-2.0-flash
GROQ_LLAMA_8B=groq/llama-3.1-8b-instant
GROQ_LLAMA_70B=groq/llama-3.3-70b-versatile

# Primary Embedding Model
EMBEDDING_MODEL=text-embedding-004

# Database & Auth (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Caching & Short-Term Memory
REDIS_URL=redis://localhost:6379

# Semantic Memory (ChromaDB Hosted)
CHROMA_HOST=api.trychroma.com
CHROMA_API_KEY=your-api-key
CHROMA_TENANT=default
CHROMA_DATABASE=default
CHROMA_COLLECTION=sql_orchestrator_memory

# Security Tuning
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
CREWAI_TRACING_ENABLED=false
